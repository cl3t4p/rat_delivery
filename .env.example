HOST="http://localhost:8080"

# Token for Agent A
TOKEN=

# Token for Agent B (required only when running index_b.js)
TOKEN_B=

# Agent name shown in the Deliveroo UI
NAME=asa_agent

# PDDL solver. Leave default if running via `npm run planner:up`.
PAAS_HOST=http://localhost:5001
# PAAS_PATH defaults to /package/dual-bfws-ffparser/solve

# LLM server (required only for Agent B)
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=
LOCAL_MODEL=llama-3.3-70b-lmstudio

# Deliberation mode (Agent B only — set at most one to true)
USE_LLM=false
USE_LLM_CODEGEN=false

# PDDL planner (both agents)
USE_PDDL=false
PDDL_FALLBACK=false