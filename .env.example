# Connection
HOST="http://localhost:8080"

# Token for the single agents (single.js / pddl.js).
TOKEN=

# Token for Agent A in the two-agent setup (multiagent_a.js).
TOKEN_A=

# Token for Agent B in the two-agent setup (multiagent_b.js).
TOKEN_B=

# Agent name shown in the Deliveroo UI.
NAME=asa_agent

# PDDL solver (planning-as-a-service)
# Read by @unitn-asa/pddl-client. Leave default if running via `npm run planner:up`.
PAAS_HOST=http://localhost:5001
# PAAS_PATH defaults to /package/dual-bfws-ffparser/solve

# Planning / deliberation modes
# USE_PDDL plans movement with the PDDL solver instead of A*.
# `npm run pddl` forces this on; `npm run single` forces it off.
# Multi-agent runs use the value below.
USE_PDDL=false

# USE_LLM chooses intentions with the LLM instead of the deterministic heuristic.
# The `:llm` npm scripts set this to true.
USE_LLM=false

# LLM server
LITELLM_BASE_URL=https://llm.bears.disi.unitn.it/v1
LITELLM_API_KEY=
LOCAL_MODEL=llama-3.3-70b-lmstudio
LLM_TIMEOUT_MS=5000
LLM_MAX_RETRIES=1
LLM_FAILURE_THRESHOLD=3
LLM_COOLDOWN_MS=120000

# Optional tuning
# Pickup scoring / opportunistic detours.
# MIN_PICKUP_SCORE=-Infinity
# LOCAL_PICKUP_MAX_DISTANCE=3
# LOCAL_PICKUP_MIN_REWARD=15
# LOCAL_PICKUP_MIN_SCORE=-25
# Spawner roaming behaviour.
# SLOW_SPAWN_MS=5000
# SPAWNER_SPARSE_THRESHOLD=0.25
# SPAWNER_DWELL_MS=1500
# Multi-agent coordination.
# USE_HEURISTIC_PREASSIGN=false   # set true to split zones before the LLM replies
# YIELDED_PARCEL_TTL_MS=2000
# LOG_COMM=false                  # set true for verbose multi-agent message logging
