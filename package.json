{
  "name": "asa_agent",
  "version": "1.0.0",
  "description": "Autonomous Software Agents project for the Deliveroo.js game.",
  "type": "module",
  "main": "src/single.js",
  "scripts": {
    "start": "npm run single",

    "agent:a": "node src/multiagent_a.js",
    "agent:b": "node src/multiagent_b.js",
    "agent:b:llm": "USE_LLM=true node src/multiagent_b.js",

    "single": "node src/single.js",
    "single:llm": "USE_LLM=true node src/single.js",
    "single:llm:policy": "USE_LLM_POLICY=true node src/single.js",
    "pddl": "node src/pddl.js",

    "planner:build": "cd planning-as-a-service/server && DOCKER_DEFAULT_PLATFORM=linux/amd64 docker build -t paas:latest .",
    "planner:up": "docker compose -f docker-compose.planner.yml up -d",
    "planner:down": "docker compose -f docker-compose.planner.yml down",
    "planner:logs": "docker compose -f docker-compose.planner.yml logs -f web worker",

    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""

  },
  "dependencies": {
    "@unitn-asa/deliveroo-js-sdk": "^1.3.5",
    "@unitn-asa/pddl-client": "^1.7.7",
    "dotenv": "^16.6.1",
    "openai": "^6.39.0"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cl3t4p/rat_delivery.git"
  },
  "keywords": [
    "autonomous-agents",
    "bdi",
    "llm",
    "pddl",
    "deliveroo-js"
  ],
  "author": "",
  "license": "ISC"
}
